<!doctype html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <link rel="stylesheet" href="/css/place.css">
</head>
<body>
<header>
    <%- include('partials/navbar') %>
</header>
<div class="page-wrap">
    <div class="place-detail-card">
        <% if (place.image_url) { %>
            <div class="place-image-wrap">
                <img
                        src="<%= place.image_url %>"
                        alt="<%= place.name %>"
                        class="place-image"
                >
            </div>
        <% } %>

        <div class="place-detail-content">
            <div class="place-detail-header">
                <h1><%= place.name %></h1>

                <% if (place.type) { %>
                    <span class="badge badge-<%= slugify(place.type) %>">
                        <%= formatLabel(place.type) %>
                    </span>
                <% } %>
            </div>

            <% if (place.address || place.city) { %>
                <p class="place-meta">
                    <strong>Location:</strong>
                    <%= place.address || '' %><%= place.address && place.city ? ', ' : '' %><%= place.city || '' %>
                </p>
            <% } %>

            <% if (place.website) { %>
                <p class="place-meta">
                    <strong>Website:</strong>
                    <a href="<%= place.website %>" target="_blank" rel="noopener noreferrer">
                        <%= place.website %>
                    </a>
                </p>
            <% } %>

            <% if(place.address && place.city) { %>
                <iframe
                        width="100%"
                        height="320"
                        style="border:0"
                        loading="lazy"
                        allowfullscreen
                        referrerpolicy="no-referrer-when-downgrade"
                        src="https://www.google.com/maps/embed/v1/place?key=<%= apiKey %>&q=<%= encodeURIComponent(`${place.address}, ${place.city}`) %>">
                </iframe>
            <% } %>

            <% if (place.items && place.items.length) { %>
                <section class="place-section">
                    <h2>Items</h2>
                    <ul class="item-list">
                        <% place.items.forEach(item => { %>
                            <li><%= formatLabel(item) %></li>
                        <% }) %>
                    </ul>
                </section>
            <% } %>

            <% if (place.schedules && place.schedules.length) { %>
                <section class="place-section">
                    <h2>Schedules</h2>
                    <div class="schedule-list">
                        <ul>
                            <% place.schedules.forEach(schedule => { %>
                                <li><%= schedule.text %></li>
                            <% }) %>
                        </ul>
                    </div>
                </section>
            <% } %>

            <div class="place-actions">
                <a href="/search" class="back-link">Back to Search</a>
            </div>
        </div>
    </div>
</div>
</body>
</html>