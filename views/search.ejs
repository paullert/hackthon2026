<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HelpHub</title>
    <link rel="stylesheet" href="css/search.css">
</head>
<body>
    <header class="hero">
        <div class="hero-inner">
            <p class="mini-title">Community Resource Finder</p>
            <h1>HelpHub</h1>
            <p class="subtitle">Find local food, shelter, campus help, and donation resources near CSUMB.</p>

            <div class="hero-buttons">
                <a href="#resources" class="hero-btn">Find Resources</a>
                <a href="/about" class="hero-btn secondary">About Us</a>
            </div>
        </div>
    </header>

    <main class="page">
        <section id="resources" class="filter-box">
            <h2>Find Help Fast</h2>
            <p class="helper-text">Choose a category or item to quickly narrow down the list.</p>

            <div class="quick-filters">
                <button class="quick-btn active" data-category="all">All</button>
                <button class="quick-btn" data-category="Food">Food</button>
                <button class="quick-btn" data-category="Shelter">Shelter</button>
                <button class="quick-btn" data-category="Campus Help">Campus Help</button>
                <button class="quick-btn" data-category="Donations">Donations</button>
            </div>

            <div class="filters-row">
                <div class="filter-group">
                    <label for="categoryFilter">Category</label>
                    <select id="categoryFilter">
                        <option value="all">All Categories</option>
                        <option value="Food">Food</option>
                        <option value="Shelter">Shelter</option>
                        <option value="Campus Help">Campus Help</option>
                        <option value="Donations">Donations</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label for="itemFilter">Item</label>
                    <select id="itemFilter">
                        <option value="all">All Items</option>
                        <option value="Food">Food</option>
                        <option value="Clothes">Clothes</option>
                        <option value="Hygiene">Hygiene</option>
                        <option value="Canned Goods">Canned Goods</option>
                        <option value="Produce">Produce</option>
                        <option value="School Supplies">School Supplies</option>
                        <option value="Emergency Support">Emergency Support</option>
                        <option value="Household Items">Household Items</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>&nbsp;</label>
                    <button id="clearFilters" class="clear-btn">Clear Filters</button>
                </div>
            </div>

            <p id="resultsCount" class="results-count">Showing 5 resources</p>
        </section>

        <section id="cardsContainer" class="cards-grid">
            <div class="resource-card" data-category="Campus Help" data-items="Food,Hygiene,School Supplies,Emergency Support">
                <div class="card-top">
                    <span class="card-badge badge-campus-help">Campus Help</span>
                </div>
                <h3>CSUMB OtterCare / The Hub</h3>
                <p class="address">100 Campus Center, Seaside, CA</p>
                <p>Basic needs support for students, including food, hygiene, and emergency help.</p>
                <a class="map-btn" target="_blank" href="https://www.google.com/maps/search/?api=1&query=100+Campus+Center+Seaside+CA">Open in Maps</a>
            </div>

            <div class="resource-card" data-category="Food" data-items="Food,Canned Goods,Produce">
                <div class="card-top">
                    <span class="card-badge badge-food">Food</span>
                </div>
                <h3>Food Bank for Monterey County - Marina</h3>
                <p class="address">Marina, CA</p>
                <p>Food distribution support for local families and individuals.</p>
                <a class="map-btn" target="_blank" href="https://www.google.com/maps/search/?api=1&query=Marina+CA+Food+Bank+for+Monterey+County">Open in Maps</a>
            </div>

            <div class="resource-card" data-category="Food" data-items="Food,Produce,Canned Goods">
                <div class="card-top">
                    <span class="card-badge badge-food">Food</span>
                </div>
                <h3>Food Bank for Monterey County - Seaside</h3>
                <p class="address">Seaside, CA</p>
                <p>Community food assistance and pantry support near CSUMB.</p>
                <a class="map-btn" target="_blank" href="https://www.google.com/maps/search/?api=1&query=Seaside+CA+Food+Bank+for+Monterey+County">Open in Maps</a>
            </div>

            <div class="resource-card" data-category="Shelter" data-items="Food,Clothes,Hygiene">
                <div class="card-top">
                    <span class="card-badge badge-shelter">Shelter</span>
                </div>
                <h3>Salvation Army Monterey Peninsula Corps</h3>
                <p class="address">Seaside, CA</p>
                <p>Provides food support, basic aid, and shelter-related assistance.</p>
                <a class="map-btn" target="_blank" href="https://www.google.com/maps/search/?api=1&query=Salvation+Army+Monterey+Peninsula+Corps+Seaside+CA">Open in Maps</a>
            </div>

            <div class="resource-card" data-category="Donations" data-items="Clothes,Household Items">
                <div class="card-top">
                    <span class="card-badge badge-donations">Donations</span>
                </div>
                <h3>Goodwill Donation Center</h3>
                <p class="address">Monterey, CA</p>
                <p>Accepts clothing and household donations for community reuse.</p>
                <a class="map-btn" target="_blank" href="https://www.google.com/maps/search/?api=1&query=Goodwill+Donation+Center+Monterey+CA">Open in Maps</a>
            </div>
        </section>
    </main>

    <script src="js/search.js">

    </script>
</body>
</html>