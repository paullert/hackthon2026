<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HelpHub</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f3f8fc;
            color: #1f2937;
        }

        .hero {
            background: linear-gradient(135deg, #2563eb, #38bdf8);
            color: white;
            padding: 56px 20px;
        }

        .hero-inner {
            max-width: 1050px;
            margin: 0 auto;
        }

        .mini-title {
            margin: 0 0 8px;
            font-size: 0.9rem;
            font-weight: bold;
            opacity: 0.95;
        }

        .hero h1 {
            margin: 0 0 12px;
            font-size: 3rem;
        }

        .subtitle {
            margin: 0;
            font-size: 1.1rem;
            max-width: 700px;
            line-height: 1.5;
        }

        .hero-buttons {
            margin-top: 20px;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .hero-btn {
            display: inline-block;
            padding: 10px 16px;
            background: white;
            color: #1d4ed8;
            border-radius: 999px;
            text-decoration: none;
            font-weight: bold;
        }

        .hero-btn.secondary {
            background: rgba(255,255,255,0.18);
            color: white;
            border: 1px solid rgba(255,255,255,0.45);
        }

        .page {
            max-width: 1050px;
            margin: 0 auto;
            padding: 24px 16px 40px;
        }

        .filter-box {
            background: white;
            border-radius: 18px;
            padding: 24px;
            box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
            margin-bottom: 24px;
        }

        .filter-box h2 {
            margin: 0 0 8px;
            color: #1d4ed8;
        }

        .helper-text {
            margin: 0 0 18px;
            color: #6b7280;
        }

        .quick-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 18px;
        }

        .quick-btn {
            border: none;
            border-radius: 999px;
            padding: 10px 16px;
            background: #dbeafe;
            color: #1d4ed8;
            font-weight: bold;
            cursor: pointer;
        }

        .quick-btn.active {
            background: #1d4ed8;
            color: white;
        }

        .filters-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
        }

        .filter-group label {
            margin-bottom: 8px;
            font-weight: bold;
            color: #374151;
        }

        .filter-group select,
        .clear-btn {
            height: 44px;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            padding: 0 12px;
            font-size: 16px;
        }

        .clear-btn {
            background: #111827;
            color: white;
            border: none;
            cursor: pointer;
            font-weight: bold;
        }

        .results-count {
            margin-top: 16px;
            font-weight: bold;
            color: #1d4ed8;
        }

        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
            gap: 22px;
        }

        .resource-card {
            background: white;
            border-radius: 22px;
            padding: 22px;
            box-shadow: 0 12px 28px rgba(0,0,0,0.08);
            border-top: 6px solid #2563eb;
            transition: transform 0.18s ease, box-shadow 0.18s ease;
        }

        .resource-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 34px rgba(0,0,0,0.12);
        }

        .card-top {
            margin-bottom: 14px;
        }

        .card-badge {
            color: white;
            border-radius: 999px;
            padding: 7px 12px;
            font-size: 0.8rem;
            font-weight: 800;
        }

        .badge-food { background: #16a34a; }
        .badge-shelter { background: #ea580c; }
        .badge-campus-help { background: #2563eb; }
        .badge-donations { background: #7c3aed; }

        .resource-card h3 {
            margin-top: 0;
            margin-bottom: 10px;
        }

        .address {
            font-weight: bold;
            color: #4b5563;
            margin-bottom: 10px;
        }

        .resource-card p {
            margin-top: 0;
            line-height: 1.5;
            color: #4b5563;
        }

        .map-btn {
            display: inline-block;
            margin-top: 10px;
            padding: 10px 14px;
            border-radius: 10px;
            background: #2563eb;
            color: white;
            text-decoration: none;
            font-weight: bold;
            font-size: 0.9rem;
        }

        .map-btn:hover {
            background: #1d4ed8;
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2.2rem;
            }

            .filters-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <header class="hero">
        <div class="hero-inner">
            <p class="mini-title">Community Resource Finder</p>
            <h1>HelpHub</h1>
            <p class="subtitle">Find local food, shelter, campus help, and donation resources near CSUMB.</p>

            <div class="hero-buttons">
                <a href="#resources" class="hero-btn">Find Resources</a>
                <a href="/about" class="hero-btn secondary">About Us</a>
            </div>
        </div>
    </header>

    <main class="page">
        <section id="resources" class="filter-box">
            <h2>Find Help Fast</h2>
            <p class="helper-text">Choose a category or item to quickly narrow down the list.</p>

            <div class="quick-filters">
                <button class="quick-btn active" data-category="all">All</button>
                <button class="quick-btn" data-category="Food">Food</button>
                <button class="quick-btn" data-category="Shelter">Shelter</button>
                <button class="quick-btn" data-category="Campus Help">Campus Help</button>
                <button class="quick-btn" data-category="Donations">Donations</button>
            </div>

            <div class="filters-row">
                <div class="filter-group">
                    <label for="categoryFilter">Category</label>
                    <select id="categoryFilter">
                        <option value="all">All Categories</option>
                        <option value="Food">Food</option>
                        <option value="Shelter">Shelter</option>
                        <option value="Campus Help">Campus Help</option>
                        <option value="Donations">Donations</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label for="itemFilter">Item</label>
                    <select id="itemFilter">
                        <option value="all">All Items</option>
                        <option value="Food">Food</option>
                        <option value="Clothes">Clothes</option>
                        <option value="Hygiene">Hygiene</option>
                        <option value="Canned Goods">Canned Goods</option>
                        <option value="Produce">Produce</option>
                        <option value="School Supplies">School Supplies</option>
                        <option value="Emergency Support">Emergency Support</option>
                        <option value="Household Items">Household Items</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>&nbsp;</label>
                    <button id="clearFilters" class="clear-btn">Clear Filters</button>
                </div>
            </div>

            <p id="resultsCount" class="results-count">Showing 5 resources</p>
        </section>

        <section id="cardsContainer" class="cards-grid">
            <div class="resource-card" data-category="Campus Help" data-items="Food,Hygiene,School Supplies,Emergency Support">
                <div class="card-top">
                    <span class="card-badge badge-campus-help">Campus Help</span>
                </div>
                <h3>CSUMB OtterCare / The Hub</h3>
                <p class="address">100 Campus Center, Seaside, CA</p>
                <p>Basic needs support for students, including food, hygiene, and emergency help.</p>
                <a class="map-btn" target="_blank" href="https://www.google.com/maps/search/?api=1&query=100+Campus+Center+Seaside+CA">Open in Maps</a>
            </div>

            <div class="resource-card" data-category="Food" data-items="Food,Canned Goods,Produce">
                <div class="card-top">
                    <span class="card-badge badge-food">Food</span>
                </div>
                <h3>Food Bank for Monterey County - Marina</h3>
                <p class="address">Marina, CA</p>
                <p>Food distribution support for local families and individuals.</p>
                <a class="map-btn" target="_blank" href="https://www.google.com/maps/search/?api=1&query=Marina+CA+Food+Bank+for+Monterey+County">Open in Maps</a>
            </div>

            <div class="resource-card" data-category="Food" data-items="Food,Produce,Canned Goods">
                <div class="card-top">
                    <span class="card-badge badge-food">Food</span>
                </div>
                <h3>Food Bank for Monterey County - Seaside</h3>
                <p class="address">Seaside, CA</p>
                <p>Community food assistance and pantry support near CSUMB.</p>
                <a class="map-btn" target="_blank" href="https://www.google.com/maps/search/?api=1&query=Seaside+CA+Food+Bank+for+Monterey+County">Open in Maps</a>
            </div>

            <div class="resource-card" data-category="Shelter" data-items="Food,Clothes,Hygiene">
                <div class="card-top">
                    <span class="card-badge badge-shelter">Shelter</span>
                </div>
                <h3>Salvation Army Monterey Peninsula Corps</h3>
                <p class="address">Seaside, CA</p>
                <p>Provides food support, basic aid, and shelter-related assistance.</p>
                <a class="map-btn" target="_blank" href="https://www.google.com/maps/search/?api=1&query=Salvation+Army+Monterey+Peninsula+Corps+Seaside+CA">Open in Maps</a>
            </div>

            <div class="resource-card" data-category="Donations" data-items="Clothes,Household Items">
                <div class="card-top">
                    <span class="card-badge badge-donations">Donations</span>
                </div>
                <h3>Goodwill Donation Center</h3>
                <p class="address">Monterey, CA</p>
                <p>Accepts clothing and household donations for community reuse.</p>
                <a class="map-btn" target="_blank" href="https://www.google.com/maps/search/?api=1&query=Goodwill+Donation+Center+Monterey+CA">Open in Maps</a>
            </div>
        </section>
    </main>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const cards = document.querySelectorAll(".resource-card");
            const categoryFilter = document.getElementById("categoryFilter");
            const itemFilter = document.getElementById("itemFilter");
            const resultsCount = document.getElementById("resultsCount");
            const quickBtns = document.querySelectorAll(".quick-btn");
            const clearBtn = document.getElementById("clearFilters");

            function updateCount() {
                let visible = 0;
                cards.forEach((card) => {
                    if (card.style.display !== "none") {
                        visible++;
                    }
                });
                resultsCount.textContent = `Showing ${visible} resource${visible === 1 ? "" : "s"}`;
            }

            function filterCards() {
                const selectedCategory = categoryFilter.value;
                const selectedItem = itemFilter.value;

                cards.forEach((card) => {
                    const category = card.dataset.category;
                    const items = card.dataset.items.split(",");

                    const categoryMatch =
                        selectedCategory === "all" || category === selectedCategory;

                    const itemMatch =
                        selectedItem === "all" || items.includes(selectedItem);

                    if (categoryMatch && itemMatch) {
                        card.style.display = "block";
                    } else {
                        card.style.display = "none";
                    }
                });

                updateCount();
            }

            quickBtns.forEach((btn) => {
                btn.addEventListener("click", function () {
                    const value = this.dataset.category;
                    categoryFilter.value = value;

                    quickBtns.forEach((b) => b.classList.remove("active"));
                    this.classList.add("active");

                    filterCards();
                });
            });

            categoryFilter.addEventListener("change", function () {
                quickBtns.forEach((b) => {
                    if (b.dataset.category === categoryFilter.value) {
                        b.classList.add("active");
                    } else {
                        b.classList.remove("active");
                    }
                });

                filterCards();
            });

            itemFilter.addEventListener("change", filterCards);

            clearBtn.addEventListener("click", function () {
                categoryFilter.value = "all";
                itemFilter.value = "all";

                quickBtns.forEach((b) => b.classList.remove("active"));
                document.querySelector('[data-category="all"]').classList.add("active");

                filterCards();
            });

            filterCards();
        });
    </script>
</body>
</html>